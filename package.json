{
  "name": "lalph",
  "type": "module",
  "version": "0.3.79",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "lalph": "./dist/cli.mjs"
  },
  "scripts": {
    "prepare": "husky && effect-language-service patch",
    "check": "concurrently \"pnpm tsgo --noEmit\" \"pnpm oxlint -c .oxlintrc.json\" \"pnpm build\"",
    "build": "tsdown",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT",
  "author": "Tim Smart <hello@timsmart.co>",
  "homepage": "https://github.com/tim-smart/lalph",
  "repository": {
    "type": "git",
    "url": "https://github.com/tim-smart/lalph.git"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2"
  },
  "optionalDependencies": {
    "@sqliteai/sqlite-vector-darwin-arm64": "0.9.93",
    "@sqliteai/sqlite-vector-darwin-x86_64": "0.9.93",
    "@sqliteai/sqlite-vector-linux-arm64": "0.9.93",
    "@sqliteai/sqlite-vector-linux-arm64-musl": "0.9.93",
    "@sqliteai/sqlite-vector-linux-x86_64": "0.9.93",
    "@sqliteai/sqlite-vector-linux-x86_64-musl": "0.9.93",
    "@sqliteai/sqlite-vector-win32-x86_64": "0.9.93"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@effect/ai-openai": "4.0.0-beta.35",
    "@effect/ai-openai-compat": "4.0.0-beta.35",
    "@effect/language-service": "^0.80.0",
    "@effect/platform-node": "4.0.0-beta.35",
    "@linear/sdk": "^78.0.0",
    "@octokit/plugin-rest-endpoint-methods": "^17.0.0",
    "@octokit/types": "^16.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260318.1",
    "clanka": "^0.2.8",
    "concurrently": "^9.2.1",
    "effect": "4.0.0-beta.35",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "octokit": "^5.0.5",
    "oxlint": "^1.56.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/ripgrep",
      "better-sqlite3",
      "tree-sitter",
      "tree-sitter-javascript",
      "tree-sitter-typescript"
    ]
  }
}
