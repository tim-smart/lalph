{
  "name": "lalph",
  "type": "module",
  "version": "0.3.70",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "lalph": "./dist/cli.mjs"
  },
  "scripts": {
    "prepare": "husky && effect-language-service patch",
    "check": "concurrently \"pnpm tsgo --noEmit\" \"pnpm oxlint -c .oxlintrc.json\" \"pnpm build\"",
    "build": "tsdown",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT",
  "author": "Tim Smart <hello@timsmart.co>",
  "homepage": "https://github.com/tim-smart/lalph",
  "repository": {
    "type": "git",
    "url": "https://github.com/tim-smart/lalph.git"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@effect/ai-openai": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/ai-openai@fe407c2",
    "@effect/ai-openai-compat": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/ai-openai-compat@fe407c2",
    "@effect/language-service": "^0.80.0",
    "@effect/platform-node": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/platform-node@fe407c2",
    "@linear/sdk": "^77.0.0",
    "@octokit/plugin-rest-endpoint-methods": "^17.0.0",
    "@octokit/types": "^16.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260317.1",
    "clanka": "^0.1.20",
    "concurrently": "^9.2.1",
    "effect": "https://pkg.pr.new/Effect-TS/effect-smol/effect@fe407c2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "octokit": "^5.0.5",
    "oxlint": "^1.56.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/ripgrep"
    ]
  }
}
